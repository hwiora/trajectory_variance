# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Trained model weights — block by default, allow only the released checkpoints
*.pt
*.pth
*.ckpt
!Counterfactual_generation/models/vae_*/best.pt
!Counterfactual_generation/models/ot_flow_*/best.pt

# Raw data and large intermediate caches (obtain separately, see README)
*.h5
*.wav
*.mp3
*.flac

# Per-run fig1_data files are included in models/ (see models/fig1_data_R*.npz)
# Do NOT ignore *.npz globally — the committed reference npz files are needed for figures

# Block original 6-feature acoustic cache; allow only the released spectral-flatness cache
Counterfactual_generation/models/acoustic_features_R*.npz

# Per-run model output dirs — block everything by default, then allow weights+config
# for the released VAE and displacement-model checkpoints
Counterfactual_generation/models/lcfm_*/
Counterfactual_generation/models/fad_*/
Counterfactual_generation/models/cellot_*/
Counterfactual_generation/models/cpa_*/
Counterfactual_generation/models/cvae_*/
Counterfactual_generation/models/condvae_*/

